# Environment variable reference for the Spending Card Authorization Service.
#
# Committed development defaults live in `.env`. Copy any value you need to
# override into `.env.local` (git-ignored) — never put real secrets in a
# committed file.

# --- Application ---
APP_ENV=dev
# Used to sign cookies/CSRF tokens. Generate a random value per environment.
APP_SECRET=change_me

# --- PostgreSQL ---
# Host is `postgres` inside Docker Compose, `127.0.0.1` from the host machine.
DATABASE_URL="postgresql://app:app@postgres:5432/cards?serverVersion=16&charset=utf8"

# --- Redis (idempotency cache, rate limiting) ---
REDIS_URL=redis://redis:6379

# --- Symfony Messenger (outbox / async work) ---
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# --- Processor signing ---
# Shared HMAC secret used to verify inbound authorization requests
# from the card processor.
PROCESSOR_SIGNING_SECRET=change_me

# --- API keys ---
# Used for the admin REST endpoints (X-API-Key header).
ADMIN_API_KEY=change_me_admin
READONLY_API_KEY=change_me_readonly

# --- Outbound webhook subscriber secrets ---
ANALYTICS_WEBHOOK_SECRET=change_me_analytics
SPONSOR_PORTAL_WEBHOOK_SECRET=change_me_sponsor

# --- AWS (floci in dev/test; real AWS endpoints in production) ---
AWS_ENDPOINT_URL=http://floci:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
OUTBOUND_WEBHOOK_QUEUE_URL=http://floci:4566/000000000000/sentinel-outbound-deliveries
